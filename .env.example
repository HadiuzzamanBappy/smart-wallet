# Firebase Configuration
# Get these values from your Firebase project settings
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-CF65XDK8FN
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual Firebase config
# 3. Get your config from: Firebase Console > Project Settings > General > Your apps

# Optional encryption settings (used by client-side AES key derivation)
# - VITE_ENC_SECRET: Master secret used to derive AES keys. In production, set this
#   to a strong secret and keep it out of source control.
# - VITE_ENC_SALT: Salt used with PBKDF2. Use a stable value per deployment.
# - VITE_ENC_ITERATIONS: PBKDF2 iterations (integer). Higher = slower but stronger.
# Example (copy to .env and update):
VITE_ENC_SECRET=smart-wallet-secure-key-2025
VITE_ENC_SALT=smart-wallet-salt-2025
VITE_ENC_ITERATIONS=100000